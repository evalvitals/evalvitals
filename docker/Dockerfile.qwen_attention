# Docker image for: model=qwen  x  analysis=attention
#
# Build:
#   docker build -f docker/Dockerfile.qwen_attention -t evalvitals-qwen-attention .
#
# Run:
#   docker run --gpus all \
#     -e HF_TOKEN=<your_token> \
#     -v $(pwd)/configs:/workspace/configs \
#     evalvitals-qwen-attention

FROM pytorch/pytorch:2.2.2-cuda12.1-cudnn8-devel

WORKDIR /workspace

# system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

# install package
COPY pyproject.toml .
COPY evalvitals/ evalvitals/

RUN pip install --no-cache-dir -e ".[viz]"

# copy assets
COPY configs/ configs/
COPY examples/ examples/

ENV HF_HOME=/workspace/.cache/huggingface
ENV TOKENIZERS_PARALLELISM=false

CMD ["python", "examples/qwen_attention.py"]
